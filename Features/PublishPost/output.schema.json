{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "publish-post_output",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "slug", "status", "created_at"],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "scheduled"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
