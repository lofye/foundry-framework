#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PHP_BIN="${PHP_BIN:-$(command -v php)}"

if [[ -z "${PHP_BIN}" ]]; then
    echo "Unable to locate a PHP binary." >&2
    exit 1
fi

has_xdebug() {
    "$1" -m 2>/dev/null | awk 'tolower($0) == "xdebug" { found = 1 } END { exit found ? 0 : 1 }'
}

if has_xdebug "${PHP_BIN}"; then
    export XDEBUG_MODE="${XDEBUG_MODE:-coverage}"
    exec "${PHP_BIN}" "${ROOT_DIR}/vendor/bin/phpunit" "$@"
fi

for candidate in \
    "/opt/homebrew/bin/php" \
    "/usr/local/bin/php" \
    "$(command -v php || true)"; do
    if [[ -n "${candidate}" && -x "${candidate}" && "${candidate}" != "${PHP_BIN}" ]] && has_xdebug "${candidate}"; then
        export XDEBUG_MODE="${XDEBUG_MODE:-coverage}"
        exec "${candidate}" "${ROOT_DIR}/vendor/bin/phpunit" "$@"
    fi
done

echo "Unable to locate a PHP executable with Xdebug enabled." >&2
echo "Set PHP_BIN to the Valet PHP executable where PIE has enabled Xdebug." >&2
exit 1
