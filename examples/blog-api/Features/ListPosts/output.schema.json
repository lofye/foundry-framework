{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "list_posts_output",
  "type": "object",
  "additionalProperties": false,
  "required": ["feature", "returned", "posts"],
  "properties": {
    "feature": {
      "type": "string"
    },
    "returned": {
      "type": "integer",
      "minimum": 1
    },
    "posts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "state"],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "state": {
            "type": "string"
          }
        }
      }
    }
  }
}
